def login(req) {
    return {
        headers: {
            "Set-Cookie": "session_id=12345; HttpOnly; Path=/",
            "Access-Control-Allow-Origin": "*"
        },
        body: "You are now logged in! Refresh the page to see your cookie."
    }
}

def profile(req) {
    if (req.cookies.session_id == "12345") {
        return "Welcome back, Admin! (Authenticated via Cookie)"
    }
    return "You are not logged in. Cookie missing."
}

set routes = {
    "GET /login": login,
    "GET /profile": profile
}

show("Listening on 8081 for Cookie test...")
http_serve(8081, routes, "public")
